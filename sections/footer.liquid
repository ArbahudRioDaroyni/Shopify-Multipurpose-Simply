<footer class="footer">
  <div class="footer__container">
    <!-- Company Information -->
    <div class="footer__column footer__column--company">
      <div class="footer__logo">
        {% if section.settings.logo %}
          {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name, class: 'footer__logo-image' }}
        {% else %}
          <h3 class="footer__logo-text">{{ shop.name }}</h3>
        {% endif %}
      </div>
      
      <div class="footer__company-info">
        {% if section.settings.address %}
          <div class="footer__address">
            {% render 'icon', name: 'location' %}
            <span>{{ section.settings.address }}</span>
          </div>
        {% endif %}
        
        {% if section.settings.email %}
          <div class="footer__contact-item">
            {% render 'icon', name: 'email' %}
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </div>
        {% endif %}
        
        {% if section.settings.phone %}
          <div class="footer__contact-item">
            {% render 'icon', name: 'phone' %}
            <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a>
          </div>
        {% endif %}
      </div>
      
      {% if section.settings.show_social_icons %}
        <div class="footer__social">
          {% for block in section.blocks %}
            {% if block.type == 'social_link' and block.settings.url != blank %}
              <a href="{{ block.settings.url }}" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="{{ block.settings.platform | capitalize }}">
                {% render 'icon', name: block.settings.platform %}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    <!-- Categories -->
    <div class="footer__column">
      <h4 class="footer__heading">{{ 'footer.categories.title' | t }}</h4>
      <ul class="footer__links">
        {% for link in section.settings.categories_menu.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    
    <!-- Information -->
    <div class="footer__column">
      <h4 class="footer__heading">{{ 'footer.information.title' | t }}</h4>
      <ul class="footer__links">
        {% for link in section.settings.information_menu.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    
    <!-- Useful Links -->
    <div class="footer__column">
      <h4 class="footer__heading">{{ 'footer.useful_links.title' | t }}</h4>
      <ul class="footer__links">
        {% for link in section.settings.useful_links_menu.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    
    <!-- Newsletter Signup -->
    <div class="footer__column footer__column--newsletter">
      <h4 class="footer__heading">{{ 'footer.newsletter.title' | t }}</h4>
      <p class="footer__newsletter-text">{{ 'footer.newsletter.description' | t }}</p>
      
      {% form 'customer', class: 'footer__newsletter-form' %}
        <div class="footer__newsletter-input-wrapper">
          <input type="email" name="contact[email]" placeholder="{{ 'footer.newsletter.email_placeholder' | t }}" class="footer__newsletter-input" required>
          <button type="submit" class="footer__newsletter-button">
            {{ 'footer.newsletter.subscribe' | t }}
          </button>
        </div>
      {% endform %}
      
      {% if section.settings.show_payment_icons %}
        <div class="footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
  
  <!-- Copyright -->
  <div class="footer__bottom">
    <div class="footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name | link_to: routes.root_url }}. {{ 'footer.copyright.rights_reserved' | t }}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-background-secondary, #f8f9fa);
    padding: 4rem 0 1rem;
    margin-top: 4rem;
    border-top: 1px solid var(--color-border, #e9ecef);
  }
  
  .footer__container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .footer__column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .footer__column--company {
    grid-column: span 1;
  }
  
  @media (min-width: 768px) {
    .footer__container {
      grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
      gap: 3rem;
    }
    
    .footer__column--company {
      grid-column: span 1;
    }
  }
  
  .footer__logo-image {
    max-width: 150px;
    height: auto;
  }
  
  .footer__logo-text {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    color: var(--color-foreground);
  }
  
  .footer__company-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-foreground-subtle, #6c757d);
  }
  
  .footer__address,
  .footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }
  
  .footer__contact-item a {
    color: inherit;
    text-decoration: none;
  }
  
  .footer__contact-item a:hover {
    color: var(--color-foreground);
  }
  
  .footer__social {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  
  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background-color: var(--color-foreground-subtle, #e9ecef);
    color: var(--color-foreground);
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .footer__social-link:hover {
    background-color: var(--color-foreground);
    color: var(--color-background);
    transform: translateY(-2px);
  }
  
  .footer__heading {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-foreground);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .footer__links li {
    margin: 0;
  }
  
  .footer__links a {
    color: var(--color-foreground-subtle, #6c757d);
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: color 0.2s ease;
  }
  
  .footer__links a:hover {
    color: var(--color-foreground);
  }
  
  .footer__column--newsletter {
    max-width: 300px;
  }
  
  .footer__newsletter-text {
    font-size: 0.9rem;
    color: var(--color-foreground-subtle, #6c757d);
    line-height: 1.4;
    margin: 0;
  }
  
  .footer__newsletter-form {
    margin-top: 1rem;
  }
  
  .footer__newsletter-input-wrapper {
    display: flex;
    border-radius: 25px;
    overflow: hidden;
    border: 1px solid var(--color-border, #e9ecef);
    background-color: var(--color-background);
  }
  
  .footer__newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: none;
    background: transparent;
    color: var(--color-foreground);
    font-size: 0.9rem;
  }
  
  .footer__newsletter-input::placeholder {
    color: var(--color-foreground-subtle, #6c757d);
  }
  
  .footer__newsletter-input:focus {
    outline: none;
  }
  
  .footer__newsletter-button {
    padding: 0.75rem 1.5rem;
    background-color: var(--color-foreground);
    color: var(--color-background);
    border: none;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  
  .footer__newsletter-button:hover {
    background-color: var(--color-foreground-hover, #343a40);
  }
  
  .footer__payment {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  
  .footer__payment-icon {
    width: 40px;
    height: 25px;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  
  .footer__payment-icon:hover {
    opacity: 1;
  }
  
  .footer__bottom {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border, #e9ecef);
    text-align: center;
  }
  
  .footer__copyright {
    font-size: 0.85rem;
    color: var(--color-foreground-subtle, #6c757d);
  }
  
  .footer__copyright a {
    color: inherit;
    text-decoration: none;
  }
  
  .footer__copyright a:hover {
    color: var(--color-foreground);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "blocks": [
    {
      "type": "social_link",
      "name": "t:labels.social_link",
      "settings": [
        {
          "type": "select",
          "id": "platform",
          "label": "t:labels.social_platform",
          "options": [
            { "value": "facebook", "label": "Facebook" },
            { "value": "twitter", "label": "Twitter" },
            { "value": "instagram", "label": "Instagram" },
            { "value": "youtube", "label": "YouTube" },
            { "value": "pinterest", "label": "Pinterest" },
            { "value": "linkedin", "label": "LinkedIn" }
          ],
          "default": "facebook"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:labels.url"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:labels.company_information"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "t:labels.address",
      "placeholder": "184 Main Rd E, St Albans VIC 3021, Australia"
    },
    {
      "type": "text",
      "id": "email",
      "label": "t:labels.email",
      "placeholder": "contact@company.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "t:labels.phone",
      "placeholder": "+001 2233 456"
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "t:labels.show_social_icons",
      "default": true
    },
    {
      "type": "header",
      "content": "t:labels.navigation_menus"
    },
    {
      "type": "link_list",
      "id": "categories_menu",
      "label": "t:labels.categories_menu"
    },
    {
      "type": "link_list",
      "id": "information_menu",
      "label": "t:labels.information_menu"
    },
    {
      "type": "link_list",
      "id": "useful_links_menu",
      "label": "t:labels.useful_links_menu"
    },
    {
      "type": "header",
      "content": "t:labels.payment_options"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
