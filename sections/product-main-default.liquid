{% comment %}
  Product main section with image gallery and product info
{% endcomment %}

{% assign selected_variant = product.selected_or_first_available_variant %}

<main class="product-main__wrapper container">
  <!-- Product Images -->
  {% render 'product-gallery' %}

  <div class="product-main__info">
    <h1 class="product-info__title">{{ product.title }}</h1>

    <div class="product-info__sku_vendor_reviews">
      <span class="product-info__sku">
        {{- 'products.sku' | t -}}: <b data-product-sku>{{ product.selected_or_first_available_variant.sku }}</b>
      </span>

      <a class="product-info__vendor text-link" href="{{ product.vendor | url_for_vendor }}">
        {{- 'products.supplier' | t -}}: <b>{{ product.vendor }}</b>
      </a>

      <hr class="spacer" />

      {% render 'product-review-badge' %}
    </div>

    <div class="product-info__price-availability-promotions">
      <div class="product-info__price" role="region" aria-live="polite">
        <div class="product-price__top">
          <span class="visually-hidden">Sale price</span>
          <strong class="product-price__sale" data-product-price-sale>{{ selected_variant.price | money }}</strong>
          {% if product.handle != 'tradeperks-membership' %}
            <span class="product-price__gst">(<span data-product-price-gst>{{ selected_variant.price | divided_by: 1.1 | money }}</span> excl GST)</span>
          {% endif %}
        </div>

        <div class="product-price__bottom" {% if selected_variant.compare_at_price == blank %}style="display: none" aria-hidden="true"{% endif %}>
          <span class="visually-hidden">Regular price</span>
          <b><s class="product-price__compare" data-product-price-compare>{{ selected_variant.compare_at_price | money }}</s></b>
          {%- assign discount_amount = selected_variant.compare_at_price | minus: selected_variant.price | money -%}
          {%- assign discount_percentage = selected_variant.compare_at_price | minus: selected_variant.price | times: 100.0 | divided_by: selected_variant.compare_at_price | round | append: '%' -%}
          <span class="product-price__discount-badge">Save <b><span data-product-discount-amount>{{ discount_amount }}</span> (<span data-product-discount-percentage>{{ discount_percentage }}</span>)</b></span>
        </div>
      </div>

      <hr class="spacer" style="--height: 40px; --space: 32px;" />

      <div class="product-info__availability-promotions">
        {% if product.handle != 'tradeperks-membership' %}
          <div class="product-availability" role="status" aria-live="polite">
            {% if selected_variant.available %}
              <span class="dot available"></span>
              <span>In Stock</span>
            {% else %}
              <span class="dot out-of-stock"></span>
              <span>Out of Stock</span>
            {% endif %}
          </div>
        {% endif %}
        <a class="product-promotion text-link" href="https://www.plumbersupplies.com.au/pages/tradeperks" target="_blank">TradePerks! You get 5% cashback on every order</a>
      </div>
    </div>

    {% liquid
      assign collections_title = product.collections | map: 'title' | join: ', '
      if collections_title contains 'SALE'
        for collection in product.collections
          if collection.title == 'SALE'
            assign description = collection.description | strip_html | strip_newlines
            render 'upsell-countdown', end_date: "2026-12-28T23:59:59Z", message_before: description, message_after: "The sale has ended.", class: "product-info__countdown"
          endif
        endfor
      endif
    %}

    <!-- Product Variant Selector -->
    {% if product.variants.size > 1 %}
      <div class="product-info__variant-selector" data-variant-id={{ product.selected_or_first_available_variant.id }}>
        {% for option in product.options %}
          <div class="product-variant-selector__option-group">
            {% assign option_name = 'option' | append: forloop.index %}
            {% assign variant_option_selected = product.selected_or_first_available_variant[option_name] %}
            {% assign option_values = '' %}
            {% assign option_values = product.variants | map: option_name | uniq %}

            <span class="product-variant-selector__label">{{ option }}: <strong>{{ variant_option_selected }}</strong></span>
            <div class="product-variant-selector__options">
              {% for value in option_values %}
                {% assign variant = product.variants | find: option_name, value %}
                {% assign image = variant.featured_image %}

                <figure class="product-variant-selector__option {% if image %}has-image{% endif %}">
                  {% assign attr_option = 'fetchpriority="high"' | append: ' data-option-name="' | append: value | append: '"' %}
                  {% assign class_image_option = 'product-variant-selector__option-image' %}
                  {% assign class_active_option = '' %}
                  {% if variant_option_selected == value %}
                    {% assign class_active_option = ' selected' %}
                    {% assign class_image_option = class_image_option | append: class_active_option %}
                  {% endif %}
                  {% if image %}
                    {% assign thumb_size = 86 %}
                    {% render 'image',
                      image: image,
                      alt: value,
                      class: class_image_option,
                      width: thumb_size,
                      height: thumb_size,
                      crop: 'center',
                      w_min: thumb_size,
                      w_max: thumb_size,
                      attr: attr_option,
                      wrapper: false
                    %}
                  {% else %}
                    <div class="product-variant-selector__option-label{{ class_active_option }}" {{ attr_option }}>{{ value }}</div>
                  {% endif %}
                </figure>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% form 'product', product, class: 'product-main__form' %}
      <input type="hidden" name="id" id="selected-variant-id" value="{{ product.selected_or_first_available_variant.id }}">

      {% render 'quantity-selector', 
        style_variant: 'standard',
        input_name: 'quantity',
        initial_value: 1,
        min_value: 1,
        max_value: 999,
        unique_id: 'product-quantity',
        show_label: true,
        label_text: 'Quantity:',
        price: product.selected_or_first_available_variant.price,
        show_price: true,
        show_total: true,
        show_gst: true
      %}

      {% comment %} {% render 'quantity-selector-bulk',
        each_price: 699,
        box_price: 6650,
        box_size: 10,
        each_quantity: 6,
        box_quantity: 6
      %} {% endcomment %}

      <div class="product-form__actions">
        <button
          type="submit"
          class="product-main__add-to-cart button"
          {% unless selected_variant.available %}
            disabled
          {% endunless %}
        >
          {% if selected_variant.available %}
            {{ 'products.add_to_cart' | t }}
          {% else %}
            {{ 'products.sold_out' | t }}
          {% endif %}
        </button>

        {% comment %} <button type="button" class="product-main__wishlist button outline" aria-label="Add to wishlist">
          {% render 'icon-or-image', icon: 'heart', width: 24 %}
        </button>

        <button type="button" class="product-main__compare button outline" aria-label="Add to compare" hidden>
          {% render 'icon-or-image', icon: 'repeat', width: 24 %}
        </button> {% endcomment %}
      </div>

      {{ form | payment_button }}
    {% endform %}

    <div class="product-info-section__trust-bar">
      <div class="trust-bar__item">
        <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg"><mask id="mask0_35_345" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="18" height="16"><path d="M16.9541 0.5V15.5H0.5V0.5H16.9541Z" fill="white" stroke="white"/></mask><g mask="url(#mask0_35_345)"><path d="M4.72723 7.90515H2.54541M4.72723 11.5415H3.99996" stroke="black" stroke-width="1.5" stroke-linecap="square"/><path d="M13.33 12.2687H17.0908V7.90511L14.1817 6.4506L13.4544 3.5415H7.63623V12.2687H9.21514" stroke="black" stroke-width="1.5"/><path d="M1.09082 4.26886H4.72718" stroke="black" stroke-width="1.5" stroke-linecap="square"/><path d="M1.09082 0.632446H7.63628V3.54154" stroke="black" stroke-width="1.5" stroke-linecap="square"/><path d="M11.2726 15.1779C12.4777 15.1779 13.4545 14.2011 13.4545 12.9961C13.4545 11.7911 12.4777 10.8143 11.2726 10.8143C10.0676 10.8143 9.09082 11.7911 9.09082 12.9961C9.09082 14.2011 10.0676 15.1779 11.2726 15.1779Z" stroke="black" stroke-width="1.5" stroke-linecap="square"/><path d="M10.5454 5.72333V7.17784H12" stroke="black" stroke-width="1.5" stroke-linecap="square"/></g></svg>
        <span>Fast Delivery</span>
      </div>
      <div class="trust-bar__item">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><mask id="mask0_35_357" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="16" height="16"><path d="M16 0H0V16H16V0Z" fill="white"/></mask><g mask="url(#mask0_35_357)"><mask id="mask1_35_357" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="-1" y="0" width="17" height="17"><path d="M15.6362 0.206177H-0.36377V16.2062H15.6362V0.206177Z" fill="white"/></mask><g mask="url(#mask1_35_357)"><path d="M6.13623 13.2062C6.13623 12.378 5.46436 11.7062 4.63623 11.7062H1.63623C1.36123 11.7062 1.13623 11.4812 1.13623 11.2062V2.20618C1.13623 1.93118 1.36123 1.70618 1.63623 1.70618H13.6362C13.9112 1.70618 14.1362 1.93118 14.1362 2.20618V11.2062C14.1362 11.4812 13.9112 11.7062 13.6362 11.7062H9.30184C8.97684 11.7062 8.66124 11.8124 8.40184 12.0062L6.13623 13.7062V13.2062ZM6.12998 15.5874L6.13623 15.5812L9.30184 13.2062H13.6362C14.7394 13.2062 15.6362 12.3093 15.6362 11.2062V2.20618C15.6362 1.10305 14.7394 0.206177 13.6362 0.206177H1.63623C0.533104 0.206177 -0.36377 1.10305 -0.36377 2.20618V11.2062C-0.36377 12.3093 0.533104 13.2062 1.63623 13.2062H3.13623H4.63623V14.7062V14.8312V14.8406V15.0406V15.7062C4.63623 15.8968 4.74248 16.0687 4.91123 16.153C5.07998 16.2374 5.2831 16.2187 5.43623 16.1062L5.9706 15.7062L6.12998 15.5874ZM5.63623 5.70618C5.90144 5.70618 6.1558 5.60082 6.3433 5.41329C6.5309 5.22575 6.63624 4.97139 6.63624 4.70618C6.63624 4.44096 6.5309 4.18661 6.3433 3.99907C6.1558 3.81153 5.90144 3.70618 5.63623 3.70618C5.37102 3.70618 5.11666 3.81153 4.92912 3.99907C4.74159 4.18661 4.63623 4.44096 4.63623 4.70618C4.63623 4.97139 4.74159 5.22575 4.92912 5.41329C5.11666 5.60082 5.37102 5.70618 5.63623 5.70618ZM9.63624 5.70618C9.90144 5.70618 10.1558 5.60082 10.3433 5.41329C10.5309 5.22575 10.6362 4.97139 10.6362 4.70618C10.6362 4.44096 10.5309 4.18661 10.3433 3.99907C10.1558 3.81153 9.90144 3.70618 9.63624 3.70618C9.37104 3.70618 9.11664 3.81153 8.9