        <span>Caring Support</span>
      </div>
      <div class="trust-bar__item">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15.15 7.15V8.75M15.15 8.75V11.15C15.15 12.0337 14.4337 12.75 13.55 12.75H2.35C1.46634 12.75 0.75 12.0337 0.75 11.15V8.75M15.15 8.75H0.75M7.95 2.35H2.35C1.46634 2.35 0.75 3.06634 0.75 3.95V8.75M16.75 0.75L12.75 4.75L11.15 3.15" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>No Credit Card Fees</span>
      </div>
    </div>

    {% if product.metafields.custom.downloadable_content != blank %}
      <a href="{{ product.metafields.custom.downloadable_content |  file_url }}" download class="product-info__downloadable-button">
        <svg width="19" height="24" viewBox="0 0 19 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M16.2 6.6L12.3 2H2V22H16.7V7.2L16.2 6.6ZM12.5 3.8L14.9 6.6H12.5V3.8ZM15.7 21H3V3H11.5V7.6H15.7V21ZM9.7 12.5C9.8 12 10 11.4 10 10.9C10.1 10.2 10.2 9.3 9.8 8.5C9.5 7.6 8.5 6.9 7.6 7.3C7.2 7.5 6.9 7.9 6.6 8.5C6.2 9.7 6.3 11.1 7 12.3C7.1 12.5 7.2 12.7 7.4 12.8C6.7 12.9 6.1 13.2 5.5 13.5C5.1 13.8 4.2 14.5 4.1 15.5C4.1 16 4.3 16.4 4.7 16.7C5 17 5.4 17.1 5.8 17.1H6.2C7.1 16.9 7.7 16.2 8.1 15.7C8.5 15.2 8.8 14.6 9.1 13.9C9.2 13.9 9.3 14 9.4 14C9.6 14.1 9.9 14.2 10.1 14.3C11 14.6 11.8 15 12.8 15C13.7 15 14.1 14.6 14.2 14.1C14.3 13.6 14 13 13.2 12.8C12.1 12.4 10.9 12.4 9.7 12.5ZM7.3 15.1C6.9 15.7 6.4 16 6 16.1C5.7 16.2 5.4 16.1 5.2 16C5.1 15.9 5 15.8 5 15.6C5 15.2 5.5 14.7 5.9 14.4C6.5 14 7.3 13.8 8 13.7C7.9 14.2 7.6 14.6 7.3 15.1ZM9 10.7C9 11.4 8.8 12 8.6 12.5C8.3 12.4 8 12.1 7.9 11.8C7.4 10.9 7.3 9.8 7.7 8.8C7.7 8.5 7.9 8.3 8 8.2H8.1C8.4 8.2 8.7 8.5 8.9 8.8C9.1 9.3 9.2 9.9 9 10.7ZM12.9 13.7C13.1 13.8 13.2 13.9 13.2 13.9C13.2 13.9 13.1 14 12.9 14C12.2 14 11.5 13.7 10.8 13.4C11.5 13.4 12.2 13.5 12.9 13.7Z" fill="#E02412"/>
        </svg>
        Download product specifications
      </a>
    {% endif %}

    {% comment %} block accordion here {% endcomment %}
    {% content_for 'blocks' %}
  </div>
</main>

{% stylesheet %}
  .product-main {
    --pm-border-radius: var(--border-radius);
    --pm-color-option: #f7f7f7;
    --pm-border-color-option: var(--color-primary);
    --pm-text-color: var(--color-text);
    --pm-text-gst-color: #8e8e93;
  }

  .product-main__wrapper {
    display: grid;
    grid-template-columns: 2.5fr 3fr;
    gap: 2rem;
    margin-top: 2rem;
    position: relative;
  }
  @media (max-width: 991px) {
    .product-main__wrapper {
      display: flex;
      flex-direction: column;
    }
  }

  .product-main__info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  @media (max-width: 768px) and (min-width: 577px) {
    .product-main__info {
      gap: 1.25rem;
    }
  }

  .product-info__title {
    font-size: 32px;
    font-weight: normal;
    color: var(--pm-text-color);
    margin: 0;
    line-height: 48px;
  }
  @media (max-width: 768px) and (min-width: 577px) {
    .product-info__title {
      font-size: 28px;
    }
  }
  @media (max-width: 576px) {
    .product-info__title {
      font-size: 24px;
      line-height: 1.3;
    }
  }

  /* Product SKU Vendor and Review Badge */
  .product-info__sku_vendor_reviews {
    display: flex;
    gap: 12px 0;
    justify-content: flex-start;
    flex-direction: row;
    align-items: center;
    font-size: 16px;
    line-height: 20px;
    flex-wrap: wrap;
  }
  .product-info__sku {
    margin-right: 8px
  }
  .product-info__vendor {
    color: var(--pm-text-color);
  }
  /* End Product SKU Vendor and Review Badge */

  /* Product Price Availability and Promotion */
  .product-info__price-availability-promotions {
    display: flex;
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    row-gap: 20px;
  }
  .product-info__price {
    display: flex;
    gap: 8px;
    flex-direction: column;
    align-items: start;
  }
  .product-price__top, .product-price__bottom {
    display: flex;
    align-items: center;
    column-gap: 12px;
  }
  .product-price__sale {
    font-size: 24px;
    line-height: 24px;
  }
  .product-price__gst {
    font-size: 16px;
    line-height: 20px;
    color: var(--pm-text-gst-color);
  }
  .product-price__compare {
    font-size: 16px;
  }
  .product-price__discount-badge {
    background: linear-gradient(67deg, #e02412 0% 65%, #99190c);
    color: #fff;
    font-size: 12px;
    line-height: 16px;
    padding: 6px 12px;
    border-radius: 64px;
    display: flex;
    gap: 4px;
    align-items: center;
    justify-content: center;
  }
  .product-info__availability-promotions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }
  .product-availability {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    line-height: 20px;
    color: #222;
  }
  .product-availability .dot {
    margin-left: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .product-availability .dot.available {
    background: #5E9A41;
    box-shadow: 0 0 6px 2px rgba(94, 154, 65, 0.7);
  }
  .product-availability .dot.out-of-stock {
    background: #FAB83E;
    box-shadow: 0 0 6px 2px rgba(250, 184, 62, 0.7)
  }
  .product-promotion {
    font-size: 16px;
    line-height: 20px;
    text-decoration: underline;
    font-style: italic;
    font-weight: bold;
  }
  /* End Product Price Availability and Promotion */

  /* Product Variant Selector */
  .product-info__variant-selector {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .product-variant-selector__option-group {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    padding-bottom: 1rem;
  }
  .product-variant-selector__label {
    font-size: 14px;
    color: var(--pm-text-color);
    letter-spacing: 0.5px;
  }
  .product-variant-selector__options {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .product-variant-selector__option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid transparent;
    border-radius: var(--pm-border-radius);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    margin: 0;
  }
  .product-variant-selector__option:hover {
    border-color: var(--pm-border-color-option);
  }
  .product-variant-selector__option:has(.selected) {
    border-color: var(--pm-border-color-option);
    background-color: var(--pm-color-option);
    transition: all 0.3s ease;
  }
  .product-variant-selector__option:has(.selected) .product-variant-selector__label {
    color: var(--color-primary);
  }
  .product-variant-selector__option.unavailable {
    opacity: 0.5;
    cursor: not-allowed;
    position: relative;
  }
  .product-variant-selector__option.has-image.unavailable::after {
    content: '';
    position: absolute;
    top: 8px;
    left: -8px;
    width: 100%;
    height: 2px;
    background-color: #dc3545;
    transform: rotate(-45deg) scaleX(0);
    transform-origin: right center;
    animation: strikethrough 0.3s ease-out forwards;
  }
  .product-variant-selector__option .product-variant-selector__label {
    font-size: 12px;
    font-weight: normal;
    color: #666;
    text-align: center;
    text-transform: none;
    letter-spacing: normal;
  }
  .product-variant-selector__option-image {
    width: 64px;
    height: auto;
    object-fit: cover;
    background-color: hsl(from var(var(--pm-border-color-option)) h s l);
  }
  .product-variant-selector__option-label {
    width: 100%;
    white-space: nowrap;
    padding: 12px 16px;
    font-size: 16px;
    line-height: 16px;
    color: var(--color-text);
    background-color: var(--pm-color-option);
  }
  @keyframes strikethrough {
    0% {
      transform: rotate(-45deg) scaleX(0);
    }
    100% {
      transform: rotate(-45deg) scaleX(1);
    }
  }
  @media (max-width: 576px) {
    .product-variant-selector__option .product-variant-selector__label {
      font-size: 11px;
    }
  }
  /* End Product Variant Selector */

  /* Product Trust Bar */
  .product-info-section__trust-bar {
    display: flex;
    gap: 24px;
    background-color: #f7f7f7;
    padding-block: 16px;
    justify-content: center;
    border-radius: 4px;
    line-height: 1;
  }
  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 16px;
  }
  /* End Product Trust Bar */
  
  /* Product Form */
  .product-main__form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .product-form__actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .product-main__add-to-cart {
    --color: var(--color-secondary) !important;

    flex: 1;
    font-weight: bold;
  }
  @media (max-width: 768px) and (min-width: 577px) {
    .product-form__actions {
      flex-wrap: wrap;
      gap: 8px;
    }
  }
  @media (max-width: 576px) {
    .product-form__actions {
      flex-wrap: wrap;
    }
    .product-main__add-to-cart {
      width: 100%;
      order: 1;
    }
  }
  /* End Product Form */

  .product-info__downloadable-button {
