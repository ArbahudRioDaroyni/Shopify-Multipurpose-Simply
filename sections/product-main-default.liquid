{% comment %}
  Product main section with image gallery and product info
{% endcomment %}

{% assign selected_variant = product.selected_or_first_available_variant %}

<main class="product-main__wrapper container">
  <!-- Product Images -->
  {% render 'product-gallery' %}

  <div class="product-main__info">
    <h1 class="product-info__title">{{ product.title }}</h1>

    <div class="product-info__sku_vendor_reviews">
      {% if selected_variant.sku %}
        <span class="product-info__sku">
          {{- 'products.sku' | t -}}: <b data-product-sku>{{ selected_variant.sku }}</b>
        </span>
      {% endif %}

      <a class="product-info__vendor text-link" href="{{ product.vendor | url_for_vendor }}">
        {{- 'products.supplier' | t -}}: <b>{{ product.vendor }}</b>
      </a>

      <hr class="spacer" />

      {% render 'product-review-badge' %}
    </div>

    <div class="product-info__price-availability-promotions">
      <div class="product-info__price" role="region" aria-live="polite">
        <div class="product-price__top">
          <span class="visually-hidden">Sale price</span>
          <strong class="product-price__sale" data-product-price-sale>{{ selected_variant.price | money }}</strong>
          {% if product.handle != 'tradeperks-membership' %}
            <span class="product-price__gst">(<span data-product-price-gst>{{ selected_variant.price | divided_by: 1.1 | money }}</span> excl GST)</span>
          {% endif %}
        </div>

        <div class="product-price__bottom" {% if selected_variant.compare_at_price == blank %}style="display: none" aria-hidden="true"{% endif %}>
          <span class="visually-hidden">Regular price</span>
          <b><s class="product-price__compare" data-product-price-compare>{{ selected_variant.compare_at_price | money }}</s></b>
          {%- assign discount_amount = selected_variant.compare_at_price | minus: selected_variant.price | money -%}
          {%- assign discount_percentage = selected_variant.compare_at_price | minus: selected_variant.price | times: 100.0 | divided_by: selected_variant.compare_at_price | round | append: '%' -%}
          <span class="product-price__discount-badge">Save <b><span data-product-discount-amount>{{ discount_amount }}</span> (<span data-product-discount-percentage>{{ discount_percentage }}</span>)</b></span>
        </div>
      </div>

      <hr class="spacer" style="--height: 40px; --space: 32px;" />

      <div class="product-info__availability-promotions">
        {% if product.handle != 'tradeperks-membership' %}
          <div class="product-availability" role="status" aria-live="polite">
            {% if selected_variant.available %}
              <span class="dot in-stock"></span>
              <span>In Stock</span>
            {% else %}
              <span class="dot out-of-stock"></span>
              <span>Out of Stock</span>
            {% endif %}
          </div>
        {% endif %}
        {% if shop.metaobjects.product_promo_text.values %}
          {% render 'product-promotion-text' %}
        {% endif %}
      </div>
    </div>

    {% liquid
      assign collections_title = product.collections | map: 'title' | join: ', '
      if collections_title contains 'SALE'
        for collection in product.collections
          if collection.title == 'SALE'
            assign description = collection.description | strip_html | strip_newlines
            render 'upsell-countdown', end_date: "2026-12-28T23:59:59Z", message_before: description, message_after: "The sale has ended.", class: "product-info__countdown"
          endif
        endfor
      endif
    %}

    <!-- Product Variant Selector -->
    {% if product.variants.size > 1 %}
      <div class="product-info__variant-selector" data-variant-id={{ product.selected_or_first_available_variant.id }}>
        {% for option in product.options %}
          <div class="product-variant-selector__option-group">
            {% assign option_name = 'option' | append: forloop.index %}
            {% assign variant_option_selected = product.selected_or_first_available_variant[option_name] %}
            {% assign option_values = '' %}
            {% assign option_values = product.variants | map: option_name | uniq %}

            <span class="product-variant-selector__label">{{ option }}: <strong>{{ variant_option_selected }}</strong></span>
            <div class="product-variant-selector__options">
              {% for value in option_values %}
                {% assign variant = product.variants | find: option_name, value %}
                {% assign image = variant.featured_image %}

                <figure class="product-variant-selector__option {% if image %}has-image{% endif %}">
                  {% assign attr_option = 'fetchpriority="high"' | append: ' data-option-name="' | append: value | append: '"' %}
                  {% assign class_image_option = 'product-variant-selector__option-image' %}
                  {% assign class_active_option = '' %}
                  {% if variant_option_selected == value %}
                    {% assign class_active_option = ' selected' %}
                    {% assign class_image_option = class_image_option | append: class_active_option %}
                  {% endif %}
                  {% if image %}
                    {% assign thumb_size = 86 %}
                    {% render 'image',
                      image: image,
                      alt: value,
                      class: class_image_option,
                      width: thumb_size,
                      height: thumb_size,
                      crop: 'center',
                      w_min: thumb_size,
                      w_max: thumb_size,
                      attr: attr_option,
                      wrapper: false
                    %}
                  {% else %}
                    <div class="product-variant-selector__option-label{{ class_active_option }}" {{ attr_option }}>{{ value }}</div>
                  {% endif %}
                </figure>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% form 'product', product, class: 'product-main__form' %}
      <input type="hidden" name="id" id="selected-variant-id" value="{{ product.selected_or_first_available_variant.id }}">

      {% liquid
        if product.handle != 'tradeperks-membership'
          assign show_gst = true
        endif
        # Collection ID for "Box of 10 - Discount 5%" collection
        assign has_box_of_10_discount = product.collections | has: 'id', 359964442773
        # Collection ID for "Box of 24 - Discount 5%" collection
        assign has_box_of_24_discount = product.collections | has: 'id', 359975878805
        
        assign can_box = false
        if has_box_of_10_discount or has_box_of_24_discount
          assign can_box = true
        endif
        
        assign per_box = 0
        if has_box_of_10_discount
          assign per_box = 10
        elsif has_box_of_24_discount
          assign per_box = 24
        endif

        assign max_value = 999
        if product.inventory_policy != 'continue' and product.selected_or_first_available_variant.inventory_management != nil 
          assign max_value = product.selected_or_first_available_variant.inventory_quantity
        endif
      %}
      {% render 'quantity-selector', 
        style_variant: 'standard',
        input_name: 'quantity',
        initial_value: 1,
        min_value: 0,
        max_value: max_value,
        unique_id: 'product-quantity',
        show_label: true,
        label_text: 'Quantity:',
        price: product.selected_or_first_available_variant.price,
        compare_at_price: product.selected_or_first_available_variant.compare_at_price
        discount_percentage: 5
        show_price: can_box,
        show_total: can_box,
        show_gst: show_gst,
        can_box: can_box,
        box_size: per_box,
      %}
      {% if template == 'product' %}
        {% comment %} Hidden input for selected variant {% endcomment %}
        <input type="hidden" name="quantity" id="quantity-variant-id" value="1" min="0" max="{{ max_value }}">
      {% endif %}

      {% comment %} {% render 'quantity-selector-bulk',
        each_price: 699,
        box_price: 6650,
        box_size: 10,
        each_quantity: 6,
        box_quantity: 6
      %} {% endcomment %}

      <div class="product-form__actions">
        <button
          type="submit"
          class="product-main__add-to-cart button"
          {% unless selected_variant.available %}
            disabled
          {% endunless %}
        >
          {% if selected_variant.available %}
            {{ 'products.add_to_cart' | t }}
          {% else %}
            {{ 'products.sold_out' | t }}
          {% endif %}
        </button>

        {% comment %} <button type="button" class="product-main__wishlist button outline" aria-label="Add to wishlist">
          {% render 'icon-or-image', icon: 'heart', width: 24 %}
        </button>

        <button type="button" class="product-main__compare button outline" aria-label="Add to compare" hidden>
          {% render 'icon-or-image', icon: 'repeat', width: 24 %}
        </button> {% endcomment %}
      </div>

      {% if selected_variant.available %}
        {{ form | payment_button }}
      {% endif %}
    {% endform %}

    {% content_for 'block', type: 'group', id: 'product_Trust_Bar' %}

    {% if product.metafields.custom.downloadable_content != blank %}
      <a href="{{ product.metafields.custom.downloadable_content |  file_url }}" download class="product-info__downloadable-button">
        <svg width="19" height="24" viewBox="0 0 19 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M16.2 6.6L12.3 2H2V22H16.7V7.2L16.2 6.6ZM12.5 3.8L14.9 6.6H12.5V3.8ZM15.7 21H3V3H11.5V7.6H15.7V21ZM9.7 12.5C9.8 12 10 11.4 10 10.9C10.1 10.2 10.2 9.3 9.8 8.5C9.5 7.6 8.5 6.9 7.6 7.3C7.2 7.5 6.9 7.9 6.6 8.5C6.2 9.7 6.3 11.1 7 12.3C7.1 12.5 7.2 12.7 7.4 12.8C6.7 12.9 6.1 13.2 5.5 13.5C5.1 13.8 4.2 14.5 4.1 15.5C4.1 16 4.3 16.4 4.7 16.7C5 17 5.4 17.1 5.8 17.1H6.2C7.1 16.9 7.7 16.2 8.1 15.7C8.5 15.2 8.8 14.6 9.1 13.9C9.2 13.9 9.3 14 9.4 14C9.6 14.1 9.9 14.2 10.1 14.3C11 14.6 11.8 15 12.8 15C13.7 15 14.1 14.6 14.2 14.1C14.3 13.6 14 13 13.2 12.8C12.1 12.4 10.9 12.4 9.7 12.5ZM7.3 15.1C6.9 15.7 6.4 16 6 16.1C5.7 16.2 5.4 16.1 5.2 16C5.1 15.9 5 15.8 5 15.6C5 15.2 5.5 14.7 5.9 14.4C6.5 14 7.3 13.8 8 13.7C7.9 14.2 7.6 14.6 7.3 15.1ZM9 10.7C9 11.4 8.8 12 8.6 12.5C8.3 12.4 8 12.1 7.9 11.8C7.4 10.9 7.3 9.8 7.7 8.8C7.7 8.5 7.9 8.3 8 8.2H8.1C8.4 8.2 8.7 8.5 8.9 8.8C9.1 9.3 9.2 9.9 9 10.7ZM12.9 13.7C13.1 13.8 13.2 13.9 13.2 13.9C13.2 13.9 13.1 14 12.9 14C12.2 14 11.5 13.7 10.8 13.4C11.5 13.4 12.2 13.5 12.9 13.7Z" fill="#E02412"/>
        </svg>
        Download product specifications
      </a>
    {% endif %}

    {% comment %} {% content_for 'blocks' %} {% endcomment %}
    
    {% comment %} block accordion here {% endcomment %}
    {% content_for 'block', type: 'accordion', id: 'accordion_Product' %}
  </div>
</main>

{% stylesheet %}
  .product-main {
    --pm-border-radius: var(--border-radius);
    --pm-color-option: #f7f7f7;
    --pm-border-color-option: var(--color-primary);
    --pm-text-color: var(--color-text);
    --pm-text-gst-color: #8e8e93;
  }

  .product-main__wrapper {
    display: grid;
    grid-template-columns: 2.5fr 3fr;
    gap: 2rem;
    margin-top: 2rem;
    position: relative;
  }
  @media (max-width: 991px) {
    .product-main__wrapper {
      display: flex;
      flex-direction: column;
    }
  }

  .product-main__info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  @media (max-width: 768px) and (min-width: 577px) {
    .product-main__info {
      gap: 1.25rem;
    }
  }

  .product-info__title {
    font-size: 32px;
    font-weight: normal;
    color: var(--pm-text-color);
    margin: 0;
    line-height: 48px;
  }
  @media (max-width: 768px) and (min-width: 577px) {
    .product-info__title {
      font-size: 28px;
    }
  }
  @media (max-width: 576px) {
    .product-info__title {
      font-size: 24px;
      line-height: 1.3;
    }
  }

  /* Product SKU Vendor and Review Badge */
  .product-info__sku_vendor_reviews {
    display: flex;
    gap: 12px 0;
    justify-content: flex-start;
    flex-direction: row;
    align-items: center;
    font-size: 16px;
    line-height: 20px;
    flex-wrap: wrap;
  }
  .product-info__sku {
    margin-right: 8px
  }
  .product-info__vendor {
    color: var(--pm-text-color);
    text-decoration: underline;
  }
  /* End Product SKU Vendor and Review Badge */

  /* Product Price Availability and Promotion */
  .product-info__price-availability-promotions {
    display: flex;
    flex-direction: row;
    align-items: center;
    row-gap: 20px;
  }
  
  @media (max-width: 991px) {
    .product-info__price-availability-promotions {
      display: grid;
    }
  }
  .product-info__price {
    display: flex;
    gap: 8px;
    flex-direction: column;
    align-items: start;
  }
  .product-price__top, .product-price__bottom {
    display: flex;
    align-items: center;
    column-gap: 12px;
  }
  .product-price__sale {
    font-size: 24px;
    line-height: 24px;
  }
  .product-price__gst {
    font-size: 16px;
    line-height: 20px;
    color: var(--pm-text-gst-color);
    white-space: nowrap;
  }
  .product-price__compare {
    font-size: 16px;
  }
  .product-price__discount-badge {
    background: linear-gradient(67deg, #e02412 0% 65%, #99190c);
    color: #fff;
    font-size: 12px;
    line-height: 16px;
    padding: 6px 12px;
    border-radius: 64px;
    display: flex;
    gap: 4px;
    align-items: center;
    justify-content: center;
  }
  .product-info__availability-promotions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }
  .product-availability {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    line-height: 20px;
    color: #222;
  }
  .product-availability .dot {
    margin-left: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .product-availability .dot.in-stock {
    background: #5E9A41;
    box-shadow: 0 0 6px 2px rgba(94, 154, 65, 0.7);
  }
  .product-availability .dot.out-of-stock {
    background: #FAB83E;
    box-shadow: 0 0 6px 2px rgba(250, 184, 62, 0.7)
  }
  .product-promotion {
    font-size: 16px;
    line-height: 20px;
    text-decoration: underline;
    font-style: italic;
    font-weight: bold;
  }
  /* End Product Price Availability and Promotion */

  /* Product Variant Selector */
  .product-info__variant-selector {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .product-variant-selector__option-group {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .product-variant-selector__label {
    font-size: 14px;
    color: var(--pm-text-color);
    letter-spacing: 0.5px;
  }
  .product-variant-selector__options {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .product-variant-selector__option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid transparent;
    border-radius: var(--pm-border-radius);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    margin: 0;
  }
  .product-variant-selector__option:hover {
    border-color: var(--pm-border-color-option);
  }
  .product-variant-selector__option:has(.selected) {
    border-color: var(--pm-border-color-option);
    background-color: var(--pm-color-option);
    transition: all 0.3s ease;
  }
  .product-variant-selector__option:has(.selected) .product-variant-selector__label {
    color: var(--color-primary);
  }
  .product-variant-selector__option.unavailable {
    opacity: 0.5;
    cursor: not-allowed;
    position: relative;
  }
  .product-variant-selector__option.has-image.unavailable::after {
    content: '';
    position: absolute;
    top: 8px;
    left: -8px;
    width: 100%;
    height: 2px;
    background-color: #dc3545;
    transform: rotate(-45deg) scaleX(0);
    transform-origin: right center;
    animation: strikethrough 0.3s ease-out forwards;
  }
  .product-variant-selector__option .product-variant-selector__label {
    font-size: 12px;
    font-weight: normal;
    color: #666;
    text-align: center;
    text-transform: none;
    letter-spacing: normal;
  }
  .product-variant-selector__option-image {
    width: 64px;
    height: auto;
    object-fit: cover;
    background-color: hsl(from var(var(--pm-border-color-option)) h s l);
  }
  .product-variant-selector__option-label {
    width: 100%;
    white-space: nowrap;
    padding: 12px 16px;
    font-size: 16px;
    line-height: 16px;
    color: var(--color-text);
    background-color: var(--pm-color-option);
  }
  @keyframes strikethrough {
    0% {
      transform: rotate(-45deg) scaleX(0);
    }
    100% {
      transform: rotate(-45deg) scaleX(1);
    }
  }
  @media (max-width: 576px) {
    .product-variant-selector__option .product-variant-selector__label {
      font-size: 11px;
    }
  }
  /* End Product Variant Selector */

  /* Product Trust Bar */
  .product-info-section__trust-bar {
    display: flex;
    gap: 24px !important;
    background-color: #f7f7f7;
    padding-block: 16px !important;
    justify-content: center !important;
    border-radius: 4px;
    line-height: 1;
  }
  @media (max-width: 991px) {
    .product-info-section__trust-bar {
      align-items: center !important;
      flex-direction: column !important;
    }
  }
  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 16px;
  }
  /* End Product Trust Bar */
  
  /* Product Form */
  .product-main__form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .product-form__actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .product-main__add-to-cart {
    --color: var(--color-secondary) !important;

    flex: 1;
    font-weight: bold;
  }
  @media (max-width: 768px) and (min-width: 577px) {
    .product-form__actions {
      flex-wrap: wrap;
      gap: 8px;
    }
  }
  @media (max-width: 576px) {
    .product-form__actions {
      flex-wrap: wrap;
    }
    .product-main__add-to-cart {
      width: 100%;
      order: 1;
    }
  }
  /* End Product Form */

  .product-info__downloadable-button {
    margin: 0;
    padding: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #e02412;
    background: #f7f7f7;
    border-radius: 4px;
    cursor: pointer;
    justify-content: center;
    text-transform: capitalize;
  }

  /* Spacer */
  .spacer {
    --space: 24px;
    --height: 16px;
    border-right: 1px #B3B3B3 solid;
    margin: 0 var(--space);
    height: var(--height);
  }
  
  @media screen and (max-width: 768px) {
    hr.spacer {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  /**
   * Class representing the Product Price User Interface.
   * Handles DOM updates for product prices, taxes, and discounts based on variant events.
   */
  class PriceUI {
    /**
     * Create a PriceUI instance and cache necessary DOM elements.
     */
    constructor() {
      this.priceSaleElement = document.querySelector('[data-product-price-sale]');
      this.priceGSTElement = document.querySelector('[data-product-price-gst]');
      this.priceCompareElement = document.querySelector('[data-product-price-compare]');
      this.discountAmountElement = document.querySelector('[data-product-discount-amount]');
      this.discountPercentageElement = document.querySelector('[data-product-discount-percentage]');
      this.priceBottomSectionElement = document.querySelector('.product-price__bottom');
    }

    /**
     * Updates the pricing elements in the DOM when a variant changes.
     * Bound as an arrow function to maintain the lexical scope of `this`.
     * 
     * @param {CustomEvent} event - The custom event containing variant details.
     * @param {Object} event.detail - The variant data object.
     * @param {number|string} event.detail.price - The current sale price in cents.
     * @param {number|string} [event.detail.compare_at_price] - The original comparison price in cents.
     */
    update = (event) => {
      const variant = event?.detail;
      if (!variant) return;

      const priceSale = Number(variant.price || 0);
      const priceCompare = Number(variant.compare_at_price || 0);
      
      const discountAmount = priceCompare - priceSale;
      const discountPercentage = this.priceOffPercentage(priceCompare, priceSale);

      if (this.priceSaleElement) {
        this.priceSaleElement.textContent = this.priceFormatter(priceSale);
      }
      
      if (this.priceGSTElement) {
        this.priceGSTElement.textContent = this.priceFormatter(Math.round(priceSale / 1.1));
      }

      if (this.priceCompareElement) {
        if (priceCompare > priceSale) {
          this.priceBottomSectionElement.style.display = '';
          this.priceCompareElement.textContent = this.priceFormatter(priceCompare);
        } else {
          this.priceBottomSectionElement.style.display = 'none';
          return;
        }
      }

      if (this.discountAmountElement) {
        if (discountAmount > 0) {
          this.discountAmountElement.textContent = this.priceFormatter(discountAmount);
          this.discountAmountElement.style.display = '';
        } else {
          this.discountAmountElement.style.display = 'none';
        }
      }

      if (this.discountPercentageElement) {
        if (discountPercentage > 0) {
          this.discountPercentageElement.textContent = `${discountPercentage}%`;
          this.discountPercentageElement.style.display = '';
        } else {
          this.discountPercentageElement.style.display = 'none';
        }
      }
    }

    /**
     * Calculates the percentage off from the original price.
     * 
     * @param {number} originalCents - The original comparison price in cents.
     * @param {number} saleCents - The active sale price in cents.
     * @returns {number} The calculated discount percentage rounded to the nearest integer.
     */
    priceOffPercentage(originalCents, saleCents) {
      if (!originalCents || originalCents <= saleCents) return 0;
      return Math.round(((originalCents - saleCents) / originalCents) * 100);
    }

    /**
     * Formats a price value from cents into a localized USD currency string.
     * 
     * @param {number} cents - The price value in cents.
     * @returns {string} The formatted USD currency string (e.g., "$10.00").
     */
    priceFormatter(cents) {
      const dollars = cents / 100;
      return dollars.toLocaleString('en-US', {
        style: 'currency',
        currency: 'USD',
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const priceUI = new PriceUI();
    document.addEventListener('product-variant:changed', priceUI.update);
  });

  class VariantSelector {
    constructor(wrapper) {
      // Variant selector properties
      this.wrapper = wrapper;
      this.options = this.wrapper.querySelectorAll('img, .product-variant-selector__option-label');
      this.priceSale = document.querySelector('[data-product-price-sale]');
      this.priceGST = document.querySelector('[data-product-price-gst]');
      this.priceCompare = document.querySelector('[data-product-price-compare]');
      this.discountAmount = document.querySelector('[data-product-discount-amount]');
      this.discountPercentage = document.querySelector('[data-product-discount-percentage]');
      this.priceOff = document.querySelector('.product-price__off');
      this.product = null;
      this.variant = null;
      
      // Availability management properties
      this.optionGroups = [];
      this.variantMatrix = {};
      this.currentSelection = [];
      
      this.init();
    }

    async init() {
      // Initialize product data
      await this.setProduct()

      // Initialize variant selector
      this.setVariant();

      // Initialize availability management
      this.initAvailabilityManager();

      this.options.forEach((option) => {
        option.addEventListener('click', () => this.onOptionClick(option));
      });
    }

    /**
     * Availability Management Methods
     */
    
    initAvailabilityManager() {
      this.buildOptionGroups();
      this.buildVariantMatrix();
      this.setInitialSelection();
      this.updateAllOptionsAvailability();
    }
    
    // Build option groups structure
    buildOptionGroups() {
      const groups = this.wrapper.querySelectorAll('.product-variant-selector__option-group');
      
      groups.forEach((group, groupIndex) => {
        const options = group.querySelectorAll('.product-variant-selector__option-image, .product-variant-selector__option-label');
        const optionValues = [];
        
        options.forEach(option => {
          optionValues.push({
            element: option,
            value: option.dataset.optionName,
            container: option.closest('.product-variant-selector__option')
          });
        });
        
        this.optionGroups.push({
          index: groupIndex,
          element: group,
          options: optionValues
        });
      });
    }
    
    // Build variant lookup matrix
    buildVariantMatrix() {
      if (!this.product?.variants) return;
      
      this.product.variants.forEach(variant => {
        const key = variant.options.join('_').toLowerCase().replace(/\s+/g, '-');
        this.variantMatrix[key] = {
          available: variant.available
        };
      });
    }
    
    // Set initial selection based on selected options
    setInitialSelection() {
      this.optionGroups.forEach((group, index) => {
        const selectedOption = group.options.find(opt => 
          opt.element.classList.contains('selected')
        );
        
        this.currentSelection[index] = selectedOption ? selectedOption.value : null;
      });
    }
    
    // Update selection when option is clicked
    updateAvailabilitySelection(groupIndex, optionValue) {
      this.currentSelection[groupIndex] = optionValue;
      this.updateAllOptionsAvailability();
    }
    
    // Check if a combination of options has available variant
    checkVariantAvailability(optionArray) {
      const key = optionArray.join('_').toLowerCase().replace(/\s+/g, '-');
      const variantData = this.variantMatrix[key];
      return variantData && variantData.available;
    }
    
    // Find variant by option combination
    findVariantByOptions(optionArray) {
      const key = optionArray.join('_').toLowerCase().replace(/\s+/g, '-');
      const variantData = this.variantMatrix[key];
      return variantData ? variantData.variant : null;
    }
    
    // Main availability update logic
    updateAllOptionsAvailability() {
      this.optionGroups.forEach((group, groupIndex) => {
        group.options.forEach(option => {
          // Create a copy of current selection
          const optionSelection = [...this.currentSelection];
          optionSelection[groupIndex] = option.value;
          
          // Check availability
          const isAvailable = this.checkVariantAvailability(optionSelection);
          
          // Update UI
          option.container.classList.toggle('unavailable', !isAvailable);
        });
      });
    }
    
    /**
     * Variant Selector Methods
     */

    // Fetch product data by handle
    async getProduct(params) {
      const pathSegments = window.location.pathname.split('/');
      const handle = pathSegments[pathSegments.length - 1];
      if (!handle) return null;

      try {
        const response = await fetch(`${window.Shopify.routes.root}products/${handle}.js`);
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        const data = await response.json();
        return data;
      } catch (error) {
        console.warn(`Error fetching data for handle "${handle}", please check if the product handle is correct:`, error);
        return {
          'message': 'Error fetching data for handle',
          'status': 'error',
          'handle': handle,
          'error': error
        };
      }
    }

    async setProduct() {
      this.product = await this.getProduct();
    }

    // Get currently selected variant based on selected options
    getVariant() {
      const selectedOptions = [];
      this.options.forEach((option) => {
        if (option.classList.contains('selected')) {
          selectedOptions.push(option.dataset.optionName);
        }
      });

      if (!this.product || !this.product.variants) return null;

      return this.product.variants.find((variant) => {
        return variant.options.every((option, index) => option === selectedOptions[index]);
      }) || null;
    }

    // Set the current variant
    setVariant() {
      this.variant = this.getVariant();
    }

    // Handle option click event
    onOptionClick(option) {
      if (option.closest('.product-variant-selector__option').classList.contains('unavailable')) {
        return; // Do nothing if option is unavailable
      }
      this.setOptionsSelected(option);
      
      // Update availability management selection
      const groupIndex = this.getOptionGroupIndex(option);
      const optionValue = option.dataset.optionName;
      this.updateAvailabilitySelection(groupIndex, optionValue);
      
      this.setVariant();
      if (this.variant) {
        this.setUrlParameter('variant', this.variant.id);
        this.setOptionLabel();
        this.dispatchVariantChangeEvent(this.variant);
      }
    }

    // Get index of the option group
    getOptionGroupIndex(option) {
      const optionGroup = option.closest('.product-variant-selector__option-group');
      const allGroups = this.wrapper.querySelectorAll('.product-variant-selector__option-group');
      return Array.from(allGroups).indexOf(optionGroup);
    }

    // Set selected class on the chosen option
    setOptionsSelected(option) {
      const imageGroup = option.closest('.product-variant-selector__option-group').querySelectorAll('img, .product-variant-selector__option-label');
      imageGroup.forEach((opt) => opt.classList.remove('selected'));
      option.classList.add('selected');
    }

    // Update URL parameter without reloading the page
    setUrlParameter(param, value) {
      const url = new URL(window.location);
      url.searchParams.set(param, value);
      window.history.replaceState({}, '', url);
    }

    // Update option labels to show selected values
    setOptionLabel() {
      this.wrapper.querySelectorAll('.product-variant-selector__label strong').forEach((label, index) => {
        const selectedOption = this.variant.options[index] || 'Select';
        label.textContent = selectedOption;
      });
    }

    // Dispatch custom event on variant change
    dispatchVariantChangeEvent(variant) {
      const event = new CustomEvent('product-variant:changed', { detail: variant });
      document.dispatchEvent(event);
    }
  }

  document.addEventListener('DOMContentLoaded', async function () {
    // Variant Selector With Images
    const variantOptionsWrapper = document.querySelector('.product-info__variant-selector');
    const variantSelector = new VariantSelector(variantOptionsWrapper);

