  <div class="reviews-badge__content">
    <b class="reviews-badge__rating">4.75</b>
    <span class="reviews-badge__stars" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.785 1.401 8.168L12 18.896l-7.335 3.858 1.401-8.168L.132 9.211l8.2-1.193z"></path>
      </svg>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.785 1.401 8.168L12 18.896l-7.335 3.858 1.401-8.168L.132 9.211l8.2-1.193z"></path>
      </svg>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.785 1.401 8.168L12 18.896l-7.335 3.858 1.401-8.168L.132 9.211l8.2-1.193z"></path>
      </svg>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.785 1.401 8.168L12 18.896l-7.335 3.858 1.401-8.168L.132 9.211l8.2-1.193z"></path>
      </svg>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.785 1.401 8.168L12 18.896l-7.335 3.858 1.401-8.168L.132 9.211l8.2-1.193z"></path>
      </svg>
    </span>
    <span class="reviews-badge__text"><b class="reviews-badge__count">500</b> reviews</span>
  </div>
</div>

<style>
.reviews-badge {
  display: flex;
  color: black;
  box-sizing: border-box;
}

.reviews-badge__content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
}

.reviews-badge__rating,
.reviews-badge__count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  line-height: 19px;
}

.reviews-badge__stars {
  display: flex;
  align-items: center;
  gap: 0.2rem;
  padding-bottom: 2px;
}

.reviews-badge__text {
  font-size: 18px;
  line-height: 19px;
}

.reviews-badge__stars svg {
  width: 18px;
  height: 18px;
}
</style>

<script>
  function generateStars(rating) {
    const fullStars = Math.floor(rating);
    const decimal = rating - fullStars;

    let halfStars = 0;

    if (decimal >= 0.25) {
      halfStars = 1;
    }

    const emptyStars = 5 - fullStars - halfStars;

    let html = '';

    // Full stars
    for (let i = 0; i < fullStars; i++) {
      html += fullStarSvg();
    }

    // Half star
    if (halfStars) {
      html += halfStarSvg();
    }

    // Empty stars
    for (let i = 0; i < emptyStars; i++) {
      html += emptyStarSvg();
    }

    return html;
  }

  function fullStarSvg() {
    return `
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.785 1.401 8.168L12 18.896l-7.335 3.858 1.401-8.168L.132 9.211l8.2-1.193z"/>
      </svg>
    `;
  }

  function halfStarSvg() {
    return `
      <svg width="20" height="20" viewBox="0 0 24 24">
        <defs>
          <linearGradient id="half-fill">
            <stop offset="50%" stop-color="currentColor"/>
            <stop offset="50%" stop-color="#ddd"/>
          </linearGradient>
        </defs>

        <path
          fill="url(#half-fill)"
          d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.785 1.401 8.168L12 18.896l-7.335 3.858 1.401-8.168L.132 9.211l8.2-1.193z"
        />
      </svg>
    `;
  }

  function emptyStarSvg() {
    return `
      <svg width="20" height="20" viewBox="0 0 24 24">
        <path
          fill="#ddd"
          d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.785 1.401 8.168L12 18.896l-7.335 3.858 1.401-8.168L.132 9.211l8.2-1.193z"
        />
      </svg>
    `;
  }

  async function getReviews() {
    try {
      console.log("Fetching reviews...");
      const response = await fetch(
        "https://stamped.io/api/widget/reviews/batch",
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            "data":[{
              "type":"site-badge",
              "reviewIds":null,
              "productIds":null,
              "apiKey":"pubkey-J9Ka3q83d1Y2Gak85YGmZZc39xtq5C",
              "storeUrl":"plumber-supplies-australia.myshopify.com",
              "isSyndication":true,
              "elementId":"1",
              "referralCode":null
            }]
          })
        }
      );

      const data = await response.json();
      if (!data || !data[0] || "Not Found" in data) {
        throw new Error("Invalid data received from reviews API");
      }
      document.querySelector('.reviews-badge__stars').innerHTML = generateStars(data[0].ratingAll);
      document.querySelector('.reviews-badge__rating').textContent = data[0].ratingAll.toFixed(2);
      document.querySelector('.reviews-badge__count').textContent = data[0].totalAll;

      // Remove skeleton loading class
      document.querySelector('.reviews-badge').classList.remove('skeleton-loading');
    } catch (error) {
      console.error("Error fetching reviews:", error);
      document.querySelector('.reviews-badge').classList.remove('skeleton-loading');
      // document.querySelector('.reviews-badge').style.display = 'none'; // Hide the reviews badge if there's an error
      // document.querySelector('.reviews-badge').previousElementSibling.style.display = 'none'; // Hide the spacer if there's an error

      document.querySelector('.reviews-badge__stars').innerHTML = generateStars(4.91);
      document.querySelector('.reviews-badge__rating').textContent = (4.91).toFixed(2);
      document.querySelector('.reviews-badge__count').textContent = 551;
    }
  }

  getReviews();
</script>