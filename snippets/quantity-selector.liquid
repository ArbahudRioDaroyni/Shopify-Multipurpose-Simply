{% doc %}
  Renders a quantity selector with increase/decrease buttons and input field.

  @param {string} [style_variant] - Style variant: compact, standard, large
  @param {string} [input_name] - Name attribute for the input field
  @param {number} [initial_value] - Initial quantity value
  @param {number} [min_value] - Minimum allowed value
  @param {number} [max_value] - Maximum allowed value
  @param {boolean} [show_label] - Whether to show label
  @param {boolean} [show_price] - Whether to show price per item
  @param {boolean} [show_gst] - Whether to show total price gst
  @param {boolean} [show_total] - Whether to show total price
  @param {string} [unique_id] - Unique identifier for the input

  @param {number} [price] - Price per item in cents for total calculation
  @param {number} [compare_at_price] - Compare at price per item in cents for total calculation
  @param {number} [discount_percentage] - Discount
  @param {string} [label_text] - Label text
  @param {string} [label_text_each] - Label text each
  @param {string} [label_text_box] - Label text box
  
  @param {boolean} [can_box] - Style mode: bulk or each
  @param {number} [box_size] - Number of items per box

  @example
  {% render 'quantity-selector', 
    style_variant: 'compact',
    input_name: 'updates[]',
    initial_value: item.quantity,
    min_value: 0,
    show_total: true,
    unique_id: item.key
    price: item.final_price,
  %}
{% enddoc %}

{% liquid
  assign style_variant = style_variant | default: 'standard'
  assign input_name = input_name | default: 'quantity'
  assign initial_value = initial_value | default: 1
  assign min_value = min_value | default: 0
  assign max_value = max_value | default: 999
  assign show_label = show_label | default: false
  assign show_price = show_price | default: false
  assign show_gst = show_gst | default: true
  assign show_total = show_total | default: false
  assign unique_id = unique_id | default: 'qty-' | handleize

  assign price = price | default: 0
  assign compare_at_price = compare_at_price | default: 0
  assign discount_percentage = discount_percentage | default: 0
  assign label_text = label_text | default: 'Quantity'
  assign label_text_each = label_text_each | default: 'Buy each:'
  assign label_text_box = label_text_box | default: 'Buy box:'
  
  assign can_box = can_box | default: false
  assign box_size = box_size | default: 10

  if style_variant == 'compact'
    assign input_width = 50
    assign height = 36
  elsif style_variant == 'large'
    assign input_width = 70
    assign height = 52
  else
    assign input_width = 50
    assign height = 50
  endif

  if can_box
    assign initial_value = 0
  endif
%}

<div class="quantity-selector_wrapper"
  data-quantity-selector
  {% if can_box %}data-box-size="{{ box_size }}"{%- endif %}
  data-currency-code="{{ cart.currency.iso_code | default: shop.currency | default: 'AUD' }}"
  data-price="{{ price }}"
  data-compare-at-price="{{ compare_at_price }}"
  data-discount-percentage="{{ discount_percentage }}"
>
  {% if can_box %}<p class="quantity-selector__title">Purchase options:</p>{% endif %}
  <div 
    class="quantity-selector quantity-selector__{{ style_variant }} {% if can_box %}quantity-selector__card{% endif %}"
    data-quantity-role="each"
    style="
      --quantity-width: {{ input_width }}px;
      --quantity-height: {{ height }}px;
    "
  >
    {% if show_label %}
      <label class="quantity-selector__label" for="{{ unique_id }}-each">
        {{ label_text_each }}
      </label>
    {% endif %}

    <div class="quantity-selector__controls-group">
      <div class="quantity-selector__controls">
        <button 
          type="button" 
          class="quantity-selector__btn quantity-selector__btn-decrease" 
          data-action="decrease"
          aria-label="{{ 'general.quantity.decrease' | t }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        </button>

        <input
          type="number"
          id="{{ unique_id }}-each"
          name="{{ input_name }}-ui"
          value="{{ initial_value }}"
          min="{{ min_value }}"
          max="{{ max_value }}"
          class="quantity-selector__input"
          data-quantity-input
        >

        <button 
          type="button" 
          class="quantity-selector__btn quantity-selector__btn-increase" 
          data-action="increase"
          aria-label="{{ 'general.quantity.increase' | t }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        </button>
      </div>

      {% if show_price and price %}
        <div class="quantity-selector__price-row" {% unless show_gst %}style="justify-content: center;"{% endunless %}>
          <span><b class="quantity-selector__price-per-each">{{ price | money }}</b> each</span>
          {% if show_gst %}
            <span class="quantity-selector__price__gst">(<span data-price-gst>{{ price | divided_by: 1.1 | money }}</span> excl GST)</span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if show_total %}
      {% if price %}
        {% assign total_value = price | times: initial_value %}
      {% else %}
        {% assign total_value = 0 %}
      {% endif %}
      <div class="quantity-selector__total">
        <span class="quantity-selector__total-label">{{ 'general.quantity.total' | t }}:</span>
        <span class="quantity-selector__sub-total-price" data-total-price="{{ total_value }}">
          {{ total_value | money }}
        </span>
      </div>
    {% endif %}
  </div>

  {% if can_box %}
    <div 
      class="quantity-selector quantity-selector__{{ style_variant }} {% if can_box %}quantity-selector__card{% endif %}"
      data-quantity-role="box"
      style="
        --quantity-width: {{ input_width }}px;
        --quantity-height: {{ height }}px;
      "
    >
      {% if show_label %}
        <label class="quantity-selector__label" for="{{ unique_id }}-box">
          {{ label_text_box }}
        </label>
      {% endif %}

      <div class="quantity-selector__controls-group">
        <div class="quantity-selector__controls">
          <button 
            type="button" 
            class="quantity-selector__btn quantity-selector__btn-decrease" 
            data-action="decrease"
            aria-label="{{ 'general.quantity.decrease' | t }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>

          <input
            type="number"
            id="{{ unique_id }}-box"
            name="{{ input_name }}-ui"
            value="{{ initial_value }}"
            min="{{ min_value }}"
            max="{{ max_value }}"
            class="quantity-selector__input"
            data-quantity-input
          >

          <button 
            type="button" 
            class="quantity-selector__btn quantity-selector__btn-increase" 
            data-action="increase"
            aria-label="{{ 'general.quantity.increase' | t }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
        </div>

        {% if show_price and price %}
          <div class="quantity-selector__price-row" {% unless show_gst %}style="justify-content: center;"{% endunless %}>
            {% assign box_price = price | times: box_size %}
            {% assign discounted_box_price = box_price | times: 0.05 %} {% comment %} 5% discount {% endcomment %}
            {% assign final_box_price = box_price | minus: discounted_box_price %}
            <p><b class="quantity-selector__price-per-box">{{ final_box_price | money }}</b> box of {{ box_size }}</p>
            <p><b class="quantity-selector__price-per-each-discounted">{{ price | money }}</b> each</p>
            {% if show_gst %}
              <span class="quantity-selector__price__gst">(<span data-price-gst>{{ final_box_price | divided_by: box_size | divided_by: 1.1 | money }}</span> excl GST)</span>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if show_total %}
        {% if price %}
          {% assign total_value = price | times: initial_value %}
        {% else %}
          {% assign total_value = 0 %}
        {% endif %}
        <div class="quantity-selector__total">
          <span class="quantity-selector__total-label">{{ 'general.quantity.total' | t }}:</span>
          <span class="quantity-selector__sub-total-price" data-total-price="{{ total_value }}">
            {{ total_value | money }}
          </span>
        </div>
      {% endif %}

    </div>
  {% endif %}
  
  {% if can_box %}
    <div class="quantity-selector__note">
      <p>Total: <span class="quantity-selector__note-total-price">$0.00</span> | You save: <span class="quantity-selector__note-total-savings">$0.00</span></p>
      <p>Total Quantity: <span class="quantity-selector__note-total-quantity">0</span></p>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .quantity-selector_wrapper {
    --qs-border-radius: var(--border-radius);
    --qs-label-color: var(--color-text);
    --qs-input-color: var(--color-button-primary-bg);
    --qs-border-color: var(--color-button-primary-border);
    --qs-button-color: var(--color-button-primary-bg);
    --qs-button-text-color: var(--color-button-primary-text);

    display: grid;
    gap: 16px;
    grid-template-columns: 1fr 1fr;
  }
  
  @media (max-width: 768px) {
    .quantity-selector_wrapper {
      grid-template-columns: 1fr;
    }
  }

  .quantity-selector__title {
    grid-column: span 2;
  }

  .quantity-selector {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: fit-content;
    align-items: flex-start;
    border-radius: var(--qs-border-radius, 4px);
    overflow: hidden;
    background: transparent;
  }

  .quantity-selector__card {
    border: 2px var(--qs-border-color) solid;
    padding: 14px;
    width: 100%;
  }

  .quantity-selector__card .quantity-selector__price-row,
  .quantity-selector__card .quantity-selector__total {
    font-size: 12.25px;
    justify-content: space-around;
  }

  .quantity-selector__label {
    color: var(--qs-label-color);
  }

  .quantity-selector__controls-group {
    display: flex;
    gap: 14px;
  }

  .quantity-selector__controls {
    display: flex;
    align-items: center;
    border: 2px solid var(--qs-border-color);
    border-radius: var(--qs-border-radius, 4px);
    background: white;
    overflow: hidden;
    height: var(--quantity-height);
  }

  .quantity-selector__btn {
    display: flex;
    padding-inline: .875rem;
    align-items: center;
    justify-content: center;
    width: var(--quantity-height);
    height: 100%;
    background: var(--qs-button-color);
    border: none;
    cursor: pointer;
    color: var(--qs-button-text-color);
    transition: all 0.3s ease;
    font-size: 14px;
    font-weight: 600;
  }

  .quantity-selector__btn:hover {
    color: var(--qs-button-text-color);
    background: hsl(from var(--qs-button-color) h s l / 0.9);
  }

  .quantity-selector__btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .quantity-selector__input {
    width: var(--quantity-width);
    height: 100%;
    font-size: 1.125rem;
    border: none;
    text-align: center;
    background: transparent;
    color: var(--qs-input-color);
    outline: none;
    margin-inline: 10px;
  }

  .quantity-selector__input::-webkit-outer-spin-button,
  .quantity-selector__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .quantity-selector__input[type="number"] {
    -moz-appearance: textfield;
  }

  .quantity-selector__price-row {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .quantity-selector__total {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    margin-top: 4px;
  }

  .quantity-selector__total-label {
    color: #6c757d;
  }

  .quantity-selector__sub-total-price {
    font-weight: 600;
  }

  .quantity-selector__note {
    grid-column: span 2;
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    background-color: #f9f9f9;
    border-radius: 0.5rem;
    border-left: 4px solid var(--qs-border-color);
  }

  .quantity-selector__note p {
    margin: 0.5rem 0;
    font-size: 0.95rem;
    color: #333;
  }

  .quantity-selector__note span {
    font-weight: 600;
    color: var(--qs-border-color);
  }

  /* Style variants */
  .quantity-selector__compact {
    --quantity-width: 50px;
    --quantity-height: 36px;
        grid-column: span 2;
  }

  .quantity-selector__standard {
    --quantity-width: 50px;
    --quantity-height: 46px;
        grid-column: span 2;
  }

  .quantity-selector__large {
    --quantity-width: 70px;
    --quantity-height: 52px;
        grid-column: span 2;
  }

  /* Focus states */
  /* .quantity-selector__controls:focus-within {
    border-color: var(--color-primary);
  } */

  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    border: 0 !important;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .quantity-selector__compact {
      --quantity-width: 45px;
      --quantity-height: 32px;
    }

    .quantity-selector__standard {
      --quantity-width: 50px;
      --quantity-height: 40px;
    }

    .quantity-selector__large {
      --quantity-width: 60px;
      --quantity-height: 48px;
    }
  }
{% endstylesheet %}

{% javascript %}
  /**
   * Class representing a dynamic Quantity Selector component.
   * Manages upper bounds, interactive step buttons, localized real-time subtotal calculation,
   * and responds dynamically to global product variant switching events.
   */
  class QuantitySelector {
    /**
     * Instantiate QuantitySelector and discover elements.
     * @param {HTMLElement} element - Parent root node containing data attributes.
     */
    constructor(root) {
      this.canBox = root.hasAttribute('data-box-size');

      this.elements = {
        quantity: document.querySelector('#quantity-variant-id'),
        increase: root.querySelectorAll('.quantity-selector__btn-increase'),
        decrease: root.querySelectorAll('.quantity-selector__btn-decrease'),
        totalPrice: root.querySelector('.quantity-selector__note-total-price'),
        totalQuantity: root.querySelector('.quantity-selector__note-total-quantity'),
        totalSavings: root.querySelector('.quantity-selector__note-total-savings')
      }
 
      this.eachCard = root.querySelector('[data-quantity-role="each"]');
      this.eachCardElements = {
        input: this.eachCard.querySelector('.quantity-selector__input'),
        pricePerEach: this.eachCard.querySelector('.quantity-selector__price-per-each'),
        priceGST: this.eachCard.querySelector('[data-price-gst]'),
        subTotalPrice: this.eachCard.querySelector('.quantity-selector__sub-total-price')
      }

      if (this.canBox) {
        this.boxCard = root.querySelector('[data-quantity-role="box"]');
        this.boxCardElements = {
          input: this.boxCard.querySelector('.quantity-selector__input'),
          pricePerBox: this.boxCard.querySelector('.quantity-selector__price-per-box'),
          pricePerEachDiscounted: this.boxCard.querySelector('.quantity-selector__price-per-each-discounted'),
          priceGST: this.boxCard.querySelector('[data-price-gst]'),
          subTotalPrice: this.boxCard.querySelector('.quantity-selector__sub-total-price')
        }
      }

      this.boxSize = this.canBox ? root.dataset.boxSize : 0;
      this.min = parseInt(this.elements.quantity.getAttribute('min')) || 0;
      this.max = parseInt(this.elements.quantity.getAttribute('max')) || 999;
      this.value = parseInt(this.elements.quantity.value);
      this.price = parseInt(root.dataset.price);
      this.compareAtPrice = parseInt(root.dataset.compareAtPrice);
      this.discountPercentage = parseInt(root.dataset.discountPercentage);

      this.bind();
      // this.updateControlsState();

      this.renderPriceGST();
      if (this.canBox) {
        this.renderPricePerBox();
        this.renderPricePerEachBuyBox();
        this.renderNoteTotal();
        this.renderNoteQuantity();
      }
    }

    /**
     * Attach global and element event listeners, initialize view components.
     */
    bind() {
      this.elements.increase.forEach(button => button.addEventListener('click', this.handleIncrease));
      this.elements.decrease.forEach(button => button.addEventListener('click', this.handleDecrease));
      this.eachCardElements.input?.addEventListener('change', this.handleInputChange);
      if (this.canBox) {
        this.boxCardElements.input?.addEventListener('change', this.handleInputChange);
      }
      this.eachCardElements.input?.addEventListener('input', this.handleInputChange);
      if (this.canBox) {
        this.boxCardElements.input?.addEventListener('input', this.handleInputChange);
      }
      // this.elements.input?.addEventListener('input', () => this.renderNoteTotal());
      // // Auto-select text when input is clicked or focused

      this.eachCardElements.input?.addEventListener('click', this.selectAllText);
      this.eachCardElements.input?.addEventListener('focus', this.selectAllText);
      if (this.canBox) {
        this.boxCardElements.input?.addEventListener('click', this.selectAllText);
        this.boxCardElements.input?.addEventListener('focus', this.selectAllText);
      }

      document.addEventListener('product-variant:changed', this.handleVariantChange);
    }

    getPriceDiscounted() {
      const discountMultiplier = parseFloat((100 - this.discountPercentage) / 100);
      const priceEach = (this.price * discountMultiplier) / 100;
      const finalPrice = parseFloat((Math.ceil(priceEach * 100) / 100).toFixed(2)) * 100;

      return finalPrice;
    }

    getPrice() {
      return this.value >= this.boxSize ? this.getPriceDiscounted() : this.price;
    }

    
    getSavings() {
      const baseTotalPrice = this.price * this.value;
      const discountedTotalPrice = this.getPrice() * this.value;
      return baseTotalPrice - discountedTotalPrice;
    }

    getPriceGST(price) {
      return Math.round(price / 1.1);
    }

    /**
     * Decrements internal quantity values by step boundaries.
     */
    handleDecrease = (e) => {
      const input = e.target.closest('.quantity-selector__controls').querySelector('[data-quantity-input]');
      const currentValue = parseInt(input.value) || 0;
      if (currentValue > this.min) {
        input.value = currentValue - 1;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }

    /**
     * Increments internal quantity values by step boundaries.
     */
    handleIncrease = (e) => {
      const input = e.target.closest('.quantity-selector__controls').querySelector('[data-quantity-input]');
      const currentValue = parseInt(input.value) || 0;
      if (currentValue < this.max) {
        input.value = currentValue + 1;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }

    /**
     * Orchestrates sanitization checks when changes are fired inside input controls.
     */
    handleInputChange = () => {
      const valueEach = parseInt(this.eachCardElements.input.value || 0);
      const valueBox = this.canBox ? parseInt(this.boxCardElements.input.value || 0) * this.boxSize : 0;
      const value = valueEach + valueBox;

      if (isNaN(value) || value < this.min) {
        value = this.min;
      } else if (value > this.max) {
        value = this.max;
      }

      this.value = value;

      this.setQuantity();
      // this.updateControlsState();

      this.renderSubTotalPriceEach();
      if (this.canBox) {
        this.renderSubTotalPriceBox();
        this.renderNoteTotal();
        this.renderNoteQuantity();
        this.renderNoteSavings();
      }

      this.dispatchQuantityChangeEvent(this.value);
    }

    /**
     * Hooks external variant switches to sync new prices back down into local item contexts.
     * @param {CustomEvent} event - System emitted pricing payloads.
     */
    handleVariantChange = (event) => {
      const variant = event?.detail;
      if (!variant || !variant.price) return;

      this.price = parseFloat(variant.price);

      this.renderSubTotalPriceEach();
      this.renderPricePerEach();
      this.renderPriceGST();
      if (this.canBox) {
        this.renderSubTotalPriceBox();
        this.renderPricePerBox();
        this.renderPricePerEachBuyBox();
        this.renderNoteTotal();
        this.renderNoteQuantity();
      }
    }

    renderSubTotalPriceEach() {
      if (!this.eachCardElements.subTotalPrice) return;
      const total = parseInt(this.eachCardElements.input.value || 0) * this.getPrice();
      this.eachCardElements.subTotalPrice.textContent = this.formatCurrency(total);
    }

    renderPricePerEach() {
      if (!this.eachCardElements.pricePerEach) return;
      this.eachCardElements.pricePerEach.textContent = this.formatCurrency(this.getPrice());
    }

    renderSubTotalPriceBox() {
      const total = parseInt(this.boxCardElements.input.value || 0) * this.getPrice() * this.boxSize;
      this.boxCardElements.subTotalPrice.textContent = this.formatCurrency(total);
    }

    renderPricePerBox() {
      const price = this.getPriceDiscounted() * this.boxSize;
      this.boxCardElements.pricePerBox.textContent = this.formatCurrency(price);
    }

    renderPricePerEachBuyBox() {
      const price = this.getPriceDiscounted();
      this.boxCardElements.pricePerEachDiscounted.textContent = this.formatCurrency(price);
    }

    renderPriceGST() {
      if (this.eachCardElements.priceGST) {
        this.eachCardElements.priceGST.textContent = this.formatCurrency(this.getPriceGST(this.price));
      }
      if (this.canBox) {
        this.boxCardElements.priceGST.textContent = this.formatCurrency(this.getPriceGST(this.getPriceDiscounted()));
      }
    }

    /**
     * Calculates structural subtotals and injects translated currency values into DOM.
     */
    renderNoteTotal() {
      const quantity = parseInt(this.value) || 0;
      const total = (this.getPrice() || 0) * quantity;
      
      this.elements.totalPrice.textContent = this.formatCurrency(total);
    }

    renderNoteQuantity() {
      this.elements.totalQuantity.textContent = this.value;
    }

    renderNoteSavings() {
      const savingsAmount = this.getSavings();
      if (savingsAmount > 0) {
        this.elements.totalSavings.textContent = this.formatCurrency(savingsAmount) + ' (5%)';
      } else {
        this.elements.totalSavings.textContent = this.formatCurrency(savingsAmount);
      }
    }

    setQuantity() {
      this.elements.quantity.value = this.value;
    }

    /**
     * Converts numbers directly from pennies into standardized localized strings.
     * @param {number} cents - Calculated subtotal amounts.
     * @returns {string} Fully localized structural formats.
     */
    formatCurrency(cents) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD'
      }).format(cents / 100);
    }

    /**
     * Simplifies text correction fields by selecting entire fields when clicked.
     */
    selectAllText = (e) => {
      setTimeout(() => {
        e.target?.select();
      }, 10);
    }

    // Dispatch custom event on quantity change
    dispatchQuantityChangeEvent(total) {
      const event = new CustomEvent('product-quantity:changed', { detail: total });
      document.dispatchEvent(event);
    }

    // ==========================
    /**
     * Adjusts active status of buttons and updates the running grand totals.
     */
    updateControlsState() {
      const currentValue = parseInt(this.elements.input.value) || 0;

      if (this.elements.decrease) {
        this.elements.decrease.disabled = currentValue <= this.min;
      }

      if (this.elements.increase) {
        this.elements.increase.disabled = currentValue >= this.max;
      }
    }
  }

  /**
   * Global dynamic lifecycle loader configuration.
   */
  document.addEventListener('DOMContentLoaded', () => {
    const initSelectors = (container = document) => {
      const selectors = container.querySelectorAll('[data-quantity-selector]:not([data-quantity-initialized])');
      selectors.forEach(selector => {
        new QuantitySelector(selector);
        selector.setAttribute('data-quantity-initialized', 'true');
      });
    };

    initSelectors();

    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        mutation.addedNodes.forEach((node) => {
          if (node.nodeType === Node.ELEMENT_NODE) {
            initSelectors(node.hasAttribute?.('data-quantity-selector') ? node.parentNode : node);
          }
        });
      });
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
  });
