{% doc %}
  Renders a text block.

  @example
  {% content_for 'block', type: 'text', id: 'text' %}
{% enddoc %}

<{{ block.settings.tag | default: 'p' }}
  class="text-block {{ block.settings.class }}"
  style="
    --text-align: {{ block.settings.alignment }};
    --font-size: {{ block.settings.font_size }}px;
    --font-weight: {{ block.settings.font_weight }};
    --color: {{ block.settings.color }};
    --margin: {{ block.settings.margin }}px;
    --padding: {{ block.settings.padding }}px;
    --line-height: {{ block.settings.line_height }};
  "
  {% if block.settings.tag == 'a' and block.settings.url != blank %}
    href="{{ block.settings.url }}"
  {% endif %}
  {{ block.settings.attributes }}
  {{ block.shopify_attributes }}
>
  {{ block.settings.text }}
</{{ block.settings.tag | default: 'p' }}>

{% stylesheet %}
  .text-block {
    text-align: var(--text-align);
    font-size: var(--font-size);
    font-weight: var(--font-weight);
    color: var(--color);
    margin: var(--margin);
    padding: var(--padding);
    line-height: var(--line-height);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.text.name",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "t:blocks.text.settings.text.label",
      "default": "t:blocks.text.settings.text.default"
    },
    {
      "type": "select",
      "id": "tag",
      "label": "t:blocks.text.settings.tag.label",
      "default": "p",
      "options": [
        { "value": "p", "label": "t:blocks.text.settings.tag.options.p" },
        { "value": "h1", "label": "t:blocks.text.settings.tag.options.h1" },
        { "value": "h2", "label": "t:blocks.text.settings.tag.options.h2" },
        { "value": "h3", "label": "t:blocks.text.settings.tag.options.h3" },
        { "value": "h4", "label": "t:blocks.text.settings.tag.options.h4" },
        { "value": "h5", "label": "t:blocks.text.settings.tag.options.h5" },
        { "value": "h6", "label": "t:blocks.text.settings.tag.options.h6" },
        { "value": "span", "label": "t:blocks.text.settings.tag.options.span" },
        { "value": "div", "label": "t:blocks.text.settings.tag.options.div" },
        { "value": "a", "label": "t:blocks.text.settings.tag.options.a" }
      ]
    },
    {
      "visible_if": "{{ block.settings.tag == 'a' }}",
      "type": "url",
      "id": "url",
      "label": "t:blocks.text.settings.url.label",
      "info": "t:blocks.text.settings.url.info"
    },
    {
      "type": "text",
      "id": "class",
      "label": "t:blocks.text.settings.class.label",
      "info": "t:blocks.text.settings.class.info"
    },
    {
      "type": "text",
      "id": "attributes",
      "label": "t:blocks.text.settings.attributes.label",
      "info": "t:blocks.text.settings.attributes.info"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "t:labels.font_size",
      "default": 12,
      "min": 8,
      "max": 72,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "t:labels.font_weight",
      "default": "400",
      "options": [
        { "value": "100", "label": "Thin (100)" },
        { "value": "200", "label": "Extra Light (200)" },
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi Bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra Bold (800)" },
        { "value": "900", "label": "Black (900)" }
      ]
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "t:labels.line_height",
      "default": 1.5,
      "min": 1,
      "max": 3,
      "step": 0.1
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:labels.alignment",
      "default": "left"
    },
    {
      "type": "color",
      "id": "color",
      "label": "t:labels.color",
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin",
      "label": "t:labels.margin",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "t:labels.padding",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "t:blocks.text.presets.default.name",
      "category": "t:blocks.text.presets.default.category"
    }
  ]
}
{% endschema %}
