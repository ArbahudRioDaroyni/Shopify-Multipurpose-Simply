{% doc %}
  Renders a single accordion content item with optional page-backed content.

  @example
  {% content_for 'block', type: 'accordion-content', id: 'accordion-item' %}
{% enddoc %}

{% liquid
  assign accordion_title_fallback = 'blocks.accordion_content.fallback_title' | t
  assign accordion_icon = block.settings.icon
  assign accordion_title = block.settings.title | strip | default: accordion_title_fallback
  assign accordion_display_mode = block.settings.display_mode | default: 'collapse'
  assign accordion_content = block.settings.content

  if block.settings.page != blank
    assign accordion_content = block.settings.page.content
  endif

  if block.settings.liquid != blank
    assign accordion_content = block.settings.liquid
  endif

  assign accordion_id = 'accordion-content-' | append: block.id
  if accordion_content != blank
    assign accordion_has_content = true
  else
    assign accordion_has_content = false
  endif
%}

{% if accordion_display_mode == 'show_all' %}
  <div
    class="accordion-content accordion-content--show-all"
    data-accordion-item
    data-display-mode="{{ accordion_display_mode }}"
    {{ block.shopify_attributes }}
    {% if accordion_content == blank %}hidden{% endif %}
  >
    <div class="accordion-content__header">
      <h2 class="accordion-content__title">
        {% if accordion_icon != 'none' %}
          {% render 'icon-or-image',
            icon: accordion_icon,
            width: 24,
          %}
        {% endif %}
        {{ accordion_title | escape }}
      </h2>
    </div>

    {% if accordion_has_content %}
      <div class="accordion-content__body">
        <div class="accordion-content__content">
          {{ accordion_content }}
        </div>
      </div>
    {% endif %}
  </div>
{% else %}
  <details
    class="accordion-content accordion-content--{{ accordion_display_mode }}{% if accordion_display_mode == 'view_more' %} is-expanded{% endif %}"
    data-accordion-item
    data-display-mode="{{ accordion_display_mode }}"
    {{ block.shopify_attributes }}
    {% if accordion_display_mode == 'view_more' %}
      open
    {% endif %}
    {% if accordion_content == blank %}hidden{% endif %}
  >
    <summary class="accordion-content__summary">
      <h2 class="accordion-content__title">
        {% if accordion_icon != 'none' %}
          {% render 'icon-or-image',
            icon: accordion_icon,
            width: 24,
          %}
        {% endif %}
        {{ accordion_title | escape }}
      </h2>
      <span class="accordion-content__icon" aria-hidden="true"></span>
    </summary>

    {% if accordion_has_content %}
      <div class="accordion-content__body">
        <div
          class="accordion-content__content{% if accordion_display_mode == 'view_more' %} accordion-content__content--view-more{% endif %}"
          {% if accordion_display_mode == 'view_more' %}
            id="{{ accordion_id }}-panel"
            data-accordion-view-more-content
            style="--accordion-content-max-height: 14rem;"
          {% endif %}
        >
          {{ accordion_content }}
        </div>

        {% if accordion_display_mode == 'view_more' %}
          <button
            type="button"
            class="accordion-content__toggle"
            data-accordion-view-more-toggle
            aria-controls="{{ accordion_id }}-panel"
            aria-expanded="true"
            data-more-label="{{ 'blocks.accordion_content.view_more' | t | escape }}"
            data-less-label="{{ 'blocks.accordion_content.view_less' | t | escape }}"
          >
            {{ 'blocks.accordion_content.view_less' | t }}
          </button>
        {% endif %}
      </div>
    {% endif %}
  </details>
{% endif %}

{% stylesheet %}
  .accordion-content {
    color: var(--color-text, currentColor);
  }

  .accordion-content__summary,
  .accordion-content__header {
    list-style: none;
    cursor: pointer;
  }

  .accordion-content__summary::-webkit-details-marker {
    display: none;
  }

  .accordion-content__title {
    margin: 0;
    font-size: 24px;
    font-weight: 400;
    line-height: 1;
    display: flex;
    gap: 8px;
  }
  @media (max-width: 768px){
    .accordion-content__title {
      font-size: 22px;
    }
  }

  .accordion-content__icon {
    position: relative;
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
  }

  .accordion-content__icon::before,
  .accordion-content__icon::after {
    content: '';
    position: absolute;
    inset: 50% auto auto 50%;
    width: 1rem;
    height: 2px;
    background: currentColor;
    border-radius: 999px;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .accordion-content__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .accordion-content[open] .accordion-content__icon::after {
    opacity: 0;
  }

  .accordion-content__body {
    padding-bottom: 1rem;
  }

  .accordion-content__content {
    font-size: 16px;
    line-height: 1.7;
  }

  .accordion-content__content > :first-child {
    margin-top: 0;
  }

  .accordion-content__content p {
    margin-bottom: 4px;
  }

  .accordion-content__content h3,
  .accordion-content__content h4,
  .accordion-content__content h5,
  .accordion-content__content h6 {
    margin-top: 20px;
    font-size: 20px;
    color: var(--pm-border-color-option);
  }

  .accordion-content__content a {
    color: var(--pm-border-color-option);
    text-decoration: underline;
  }
  
  .accordion-content__content table {
    width: 100%;
    border-collapse: collapse; /* Prevents double borders */
    font-family: Arial, sans-serif;
    margin: 20px 0;
    font-size: 16px;
  }

  .accordion-content__content thead {
    background-color: #f2f2f2;
    border-bottom: 2px solid #cccccc;
  }

  .accordion-content__content th,
  .accordion-content__content td {
    padding: 12px 15px;
    text-align: left;
  }

  .accordion-content__content tbody tr:nth-child(even) {
    background-color: #f9f9f9;
  }

  .accordion-content__content tbody tr {
    border-bottom: 1px solid #dddddd;
  }

  .accordion-content__content tbody tr:hover {
    background-color: #f1f1f1;
  }

  .accordion-content__content > :last-child {
    margin-bottom: 0;
  }

  .accordion-content--view_more .accordion-content__content {
    max-height: var(--accordion-content-max-height, 14rem);
    overflow: hidden;
    position: relative;
  }

  .accordion-content--view_more.is-expanded .accordion-content__content {
    max-height: none;
    overflow: visible;
  }

  .accordion-content--view_more .accordion-content__content::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 4rem;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0), var(--color-background, #fff));
    pointer-events: none;
  }

  .accordion-content--view_more.is-expanded .accordion-content__content::after {
    display: none;
  }

  .accordion-content__toggle {
    margin-top: 0.75rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--color-primary, currentColor);
    font: inherit;
    font-weight: 600;
    text-decoration: underline;
    cursor: pointer;
  }

  .accordion-content--show-all .accordion-content__header {
    cursor: default;
  }

  .accordion-content--collapse {
    scroll-margin-top: 12rem;
  }
{% endstylesheet %}

{% javascript %}
  const initAccordionViewMore = () => {
    document.querySelectorAll('[data-accordion-item][data-display-mode="view_more"]').forEach((item) => {
      if (item.dataset.viewMoreInitialized === 'true') return;

      item.dataset.viewMoreInitialized = 'true';

      const content = item.querySelector('[data-accordion-view-more-content]');
      const button = item.querySelector('[data-accordion-view-more-toggle]');

      if (!content || !button) return;

      const maxHeight = () => {
        const rawValue = getComputedStyle(content).getPropertyValue('--accordion-content-max-height').trim();
        const parsed = Number.parseFloat(rawValue);
        return Number.isFinite(parsed) ? parsed : 224;
      };

      const updateButton = () => {
        const expanded = item.classList.contains('is-expanded');
        button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        button.textContent = expanded ? button.dataset.lessLabel : button.dataset.moreLabel;
      };

      const refresh = () => {
        const shouldShow = content.scrollHeight > maxHeight() + 4;

        button.hidden = !shouldShow;

        if (!shouldShow) {
          item.classList.add('is-expanded');
        }

        updateButton();
      };

      button.addEventListener('click', () => {
        item.classList.toggle('is-expanded');
        updateButton();
      });

      refresh();

      window.addEventListener('resize', refresh, { passive: true });
    });
  };

  const initAccordionCollapseScroll = () => {
    document.querySelectorAll('[data-accordion-item][data-display-mode="collapse"]').forEach((item) => {
      if (item.dataset.collapseScrollInitialized === 'true') return;

      item.dataset.collapseScrollInitialized = 'true';

      item.addEventListener('toggle', () => {
        if (!item.open) return;

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const behavior = prefersReducedMotion ? 'auto' : 'smooth';

        window.requestAnimationFrame(() => {
          item.scrollIntoView({
            behavior,
            block: 'start',
          });
        });
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccordionViewMore, { once: true });
    document.addEventListener('DOMContentLoaded', initAccordionCollapseScroll, { once: true });
  } else {
    initAccordionViewMore();
    initAccordionCollapseScroll();
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:blocks.accordion_content.name",
  "settings": [
    {
      "type": "header",
      "content": "t:blocks.accordion_content.settings.content.header"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "t:blocks.icon.name",
      "info": "t:blocks.icon.settings.icon.info",
      "options": [
        {
          "value": "none",
          "label": "t:blocks.icon.settings.icon.options.none"
        },
        {
