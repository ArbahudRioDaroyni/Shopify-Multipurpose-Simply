          "label": "t:blocks.icon.settings.icon.options.paragraph"
        }
      ],
      "default": "none"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:blocks.accordion_content.settings.title.label"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:blocks.accordion_content.settings.content.label"
    },
    {
      "type": "page",
      "id": "page",
      "label": "t:blocks.accordion_content.settings.page.label",
      "info": "t:blocks.accordion_content.settings.page.info"
    },
    {
      "type": "liquid",
      "id": "liquid",
      "label": "t:blocks.accordion_content.settings.liquid.label",
      "info": "t:blocks.accordion_content.settings.liquid.info"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "t:blocks.accordion_content.settings.display_mode.label",
