        },
        {
          "value": "view_more",
          "label": "t:blocks.accordion_content.settings.display_mode.options.view_more"
        },
        {
          "value": "show_all",
          "label": "t:blocks.accordion_content.settings.display_mode.options.show_all"
        }
      ],
      "default": "show_all"
    }
  ],
  "presets": [
    {
      "name": "t:blocks.accordion_content.presets.default.name",
